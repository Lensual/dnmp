DOCKER_COMPOSE_NAMESPACE=dnmp
COMPOSE_PROFILES=nginx,acme,php85

# 发行版 debian/alpine
DIST_VERSION=debian

# Nginx 版本 1.30.0-trixie/1.30.0-alpine
NGINX_VERSION=1.30.0-trixie

# APK 镜像源
DOCKER_APK_MIRROR=dl-cdn.alpinelinux.org
# DOCKER_APK_MIRROR=mirrors.tuna.tsinghua.edu.cn

# APT 镜像源
DOCKER_APT_MIRROR=deb.debian.org
